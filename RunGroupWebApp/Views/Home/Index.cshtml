@using RunGroupWebApp.ViewModels
@model HomeViewModel
@{
	ViewData["Title"] = "Home Page";
}

<section class="jumbotron text-center">
	<div class="container">
		<h1 class="jumbotron-heading">RunGroup</h1>
		<p class="lead text-muted">Somthing short and leading ablut the collection below-its contents, the creator, etc.</p>
		<p>
			<a href="#" class="btn btn-primary my-2">Main call to action</a>
			<a href="#" class="btn btn-secondary my-2">Secondary action</a>
		</p>
	</div>
</section>
<div class="albun py-5 bg-light">
	<div class="container">
		<div class="row">
			<h1 class="fw-light">Running clubs near @Model.City, @Model.State</h1>
			@if (Model.Clubs == null || !Model.Clubs.Any())
			{
				 <h1 class="fw-light">There are no running clubs in your area! <a asp-area="" asp-controller="Account" asp-action="Login">Login</a> and create one!</h1>
			 }
			 else
			 {
				 @foreach (var item in Model.Clubs)
				  {
					  <div class="col-md-4">
						  <div class="card mb-4 box-shadow">
							  <img src="@item.Image" class="bd-placeholder-img card-img-top" width="100%" height="225"></img>
							  <div class="card-body">
								<p class="card-text">@item.Title</p>
								<p class="card-text">@item.Description</p>
								<div class="d-flex justify-content-between align-items-center">
									<div class="btn-group">
										<button type="button" class="btn btn-sm btn-outline-secondary">View</button>
									</div>
									<small class="text-muted">@item.ClubCategory</small>
								</div>
							  </div>
						  </div>
					  </div>
				  }
			 }
		</div>
	</div>
</div>
